android_app_import {
    name: "ViPER4AndroidFX",
    owner: "ViperFX",
    apk: "prebuilts/viperfx-release.apk",
    preprocessed: true,
    presigned: true,
    dex_preopt: {
        enabled: true,
    },
    overrides: [
        "AudioFX",
        "MusicFX",
    ],
    optional_uses_libs: [
        "androidx.window.extensions",
        "androidx.window.sidecar",
    ],
    system_ext_specific: true,
    required: ["libv4a_re"],
}
